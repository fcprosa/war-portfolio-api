# War Portfolio API / Vercel dashboard defaults
# Copy these values into your Vercel project environment variables.

DEFAULT_POSITIONS=[{"sym":"TICKER","display":"TICKER","name":"Company Name","shares":0,"avgCost":0,"badge":"hold","thesis":"Your thesis"}]
DEFAULT_WATCHLIST=[{"sym":"TICKER","display":"TICKER","name":"Company Name","badge":"watch","thesis":"Your thesis","custom":false}]
DEFAULT_CASH=~$0
DEFAULT_CASH_SUB=Description of cash allocation
DEFAULT_PREDICTION_MARKETS=[]
DEFAULT_PORTWATCH_MANUAL=null

# Vercel Blob + state protection
STATE_PIN=
BLOB_READ_WRITE_TOKEN=

# Market data
FINNHUB_KEY=

# Sprint 1 — Supabase memory layer (Gatto Farioli agent)
# Get these from Supabase project settings -> API.
# SUPABASE_SERVICE_KEY is the service_role key — server-side ONLY.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Sprint 2 — Agent endpoint (api/agent.js)
# ANTHROPIC_API_KEY is shared with the Python engine below; set it once.
# Override the default models if needed; both default to spec values.
AGENT_MODEL_BRIEF=claude-opus-4-5
AGENT_MODEL_CHAT=claude-sonnet-4-5
AGENT_MAX_TOKENS=2000

# Gatto Farioli local intelligence system secrets
# Copy to gatto_farioli/.env and fill in values as features are enabled.

# Session 3+
ANTHROPIC_API_KEY=
ANTHROPIC_MONTHLY_BUDGET_USD=15

# Session 2+
FRED_API_KEY=

# Session 5+
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
DIGEST_TO_EMAIL=
